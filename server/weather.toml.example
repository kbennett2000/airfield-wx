# airfield-wx — server config
#
# Copy this to server/weather.toml and edit for your deployment:
#     cp server/weather.toml.example server/weather.toml
# (`./install.sh` and `make dev`/`make serve` also auto-seed it if it's
# missing.) This file ships in FIXTURE / DEMO MODE — see [development] below —
# so the dashboard shows sample data with no hardware on first run. Comment out
# the [development] block to poll real ESP32 sensors at the [[sensors]] IPs.

[server]
host = "0.0.0.0"
port = 8005
db_path = "weather.db"
dashboard_dir = "../dashboard"   # relative to the working directory the server is launched from
branding_path = "../branding.toml"  # ditto; falls back to branding.toml.example if missing

[logger]
interval_seconds = 60
http_timeout_seconds = 10

[cache]
ttl_seconds = 5

# History logging — OFF by default. airfield-wx is a live-conditions instrument:
# density altitude, the runway solution, altimeter, METAR — everything you fly by
# is computed from the CURRENT reading, so the station works fully without keeping
# any history, and stays clean and stateless out of the box.
#
# Turn this on ONLY if you want the dashboard trend chart and the daily /summary.
# When off, the logger never runs, nothing is written to disk, and the /history
# and /summary endpoints return 404 ("logging disabled").
#
# It CANNOT be applied retroactively: enabling it starts logging from that moment
# — it can't recover past readings. (It's also the prerequisite for the future
# wind-history work noted in docs/future-work.md, and a separate wind station —
# topology 3 — requires it, since that station's data path IS the log.)
[logging]
enabled = false

# Flexible anemometer topology (decision 16 / ADR-0006). `source` selects where
# field wind comes from:
#   "outdoor"  (default) — wind rides the outdoor payload: an all-in-one unit, or
#               a remote anemometer cabled to the same ESP32. No second device.
#   "<id>"     — the id of a dedicated, logged wind-station [[sensors]] entry
#               (topology 3; see the commented example at the bottom of this file).
# `max_age_s` is the freshness guard: wind older than this is treated as stale and
# the wind-derived fields (incl. the favored-runway solution) are nulled — never
# present dead-sensor wind as current. ~60–120 s is sensible.
[wind]
source = "outdoor"
max_age_s = 90

# Set [development] fixture_dir to a directory containing outdoor.json
# (plus a <sensor-id>.json for any additional station) to read from local
# fixtures instead of polling real ESP32s — useful for offline development.
# Comment out (or remove) the whole [development] block to enable real HTTP
# polling of the IPs in the [[sensors]] entries below.
[development]
fixture_dir = "fixtures"

# Optional internet-sourced regional conditions (wind etc.). The server is
# OFFLINE-FIRST: if this whole section is removed, or enabled = false, or there
# is simply no internet, everything else keeps working unchanged and the
# `external` block of /api/v1/current is null. Nothing here is required.
#
# provider:
#   "open-meteo"   — keyless, global, point-specific (best_match → HRRR in US).
#                    Recommended default: most robust for an arbitrary location.
#   "nws"          — keyless, real US station observations. Auto-finds the
#                    nearest station, or set station_id to pin one.
#   "wunderground" — a specific PWS by station_id; needs a free member api_key.
#   "metar"        — keyless aviationweather.gov: ceiling, visibility, flight
#                    category, and the station altimeter (cross-checks our
#                    altimeter setting). Auto-finds the nearest reporting
#                    station, or set station_id to pin an ICAO id (e.g. "KSEA").
#                    Recommended for the aviation dashboard's METAR panel.
#
# fetch: which fields to request (open-meteo supports all of these).
# cross_check: compare the model vs the nearest NWS station and flag
#   confidence = "low" when they diverge sharply.
[external]
enabled = true
provider = "open-meteo"
refresh_interval_seconds = 300
http_timeout_seconds = 8
fetch = ["wind", "cloud", "uv", "precip", "visibility"]
cross_check = false
# station_id = "KXX00001"     # nws/metar (pin a station) or wunderground (required)
# api_key = "..."             # wunderground only (free; never the website key)
# lat_override = 0.0          # default: outdoor GPS, then its fallback_lat/lon
# lon_override = 0.0

# Airport / location intelligence. All optional: with nothing set, the nearest
# airport is resolved from the bundled OurAirports data using the outdoor GPS.
[airport]
# ident = "____"               # override the auto-detected field by ICAO/local ident
crosswind_limit_kt = 15        # flags a runway end whose crosswind exceeds this
# field_elevation_ft = 0       # manual override (else: published value, then GPS)
#
# Manual runway entry for a strip not in OurAirports. Headings are MAGNETIC
# (what's painted on the runway); the engine derives true via WMM variation.
# [[airport.runways]]
#   ident = "12/30"
#   le_heading_magnetic_deg = 120
#   length_ft = 1700
#   surface = "gravel"

[[sensors]]
id = "outdoor"
role = "outdoor"
ip = "192.168.1.60"
has_gps = true
has_light = false              # no light sensor; sky/UV come from METAR instead
has_wind = true                # set false if there's no anemometer
online_threshold_seconds = 120
temp_offset_c = -0.5
wind_vane_offset_deg = 0.0      # align the raw vane reading to true north
fallback_altitude_m = 1609.3   # used for sea-level adjustment if GPS has no fix
fallback_lat = 0.0             # used by astronomy if GPS has no fix
fallback_lon = 0.0             # used by astronomy if GPS has no fix

# OPTIONAL separate wind station (topology 3 — decision 16 / ADR-0006). A
# dedicated ESP32 + anemometer at the good wind-mounting spot, no GPS, logged
# like the outdoor unit. To enable: uncomment this block, set has_wind = false
# on the outdoor unit above (its anemometer is gone), and point [wind] source at
# this id. The vane offset travels with the device holding the anemometer.
# [[sensors]]
# id = "wind"
# role = "wind_station"
# ip = "192.168.1.61"
# has_wind = true
# online_threshold_seconds = 120
# wind_vane_offset_deg = 0.0
